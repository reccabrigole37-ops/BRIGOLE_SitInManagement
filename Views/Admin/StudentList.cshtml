@model List<BRIGOLE_SitInManagement.Models.Student>
@{
    ViewData["Title"] = "Student List";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar" style="background:var(--ccs-gold)"><i class="fas fa-user-shield"></i></div>
            <div class="user-name">@User.Identity?.Name</div>
            <div class="user-id" style="color:rgba(255,255,255,0.5)">Administrator</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="SitInRecords"><i class="fas fa-list-alt"></i>Sit-in Records</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Analytics"><i class="fas fa-chart-pie"></i>Analytics</a>
            <div class="sidebar-section-title">Students</div>
            <a class="nav-link active" asp-controller="Admin" asp-action="StudentList"><i class="fas fa-users"></i>Student List</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Leaderboard"><i class="fas fa-trophy"></i>Leaderboard</a>
            <div class="sidebar-section-title">Content</div>
            <a class="nav-link" asp-controller="Admin" asp-action="Announcements"><i class="fas fa-bullhorn"></i>Announcements</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Reservations"><i class="fas fa-calendar-check"></i>Reservations</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Feedback"><i class="fas fa-comment-dots"></i>Feedback</a>
            <a class="nav-link" asp-controller="Admin" asp-action="ExportCsv"><i class="fas fa-file-csv"></i>Export CSV</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-0" style="color:var(--ccs-purple)">Student List</h4>
                <small class="text-muted">@Model.Count registered students</small>
            </div>
        </div>

        <div class="ccs-card">
            <div class="ccs-card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-users me-2"></i>All Students</span>
                <form method="get" class="d-flex gap-2">
                    <input name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Search by name or ID..." style="width:220px" />
                    <button type="submit" class="btn btn-sm btn-gold"><i class="fas fa-search"></i></button>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table ccs-table mb-0">
                    <thead>
                        <tr>
                            <th>ID Number</th>
                            <th>Name</th>
                            <th>Course</th>
                            <th>Level</th>
                            <th>Sessions Left</th>
                            <th>Points</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td><code>@s.IdNumber</code></td>
                                <td>@s.FullName</td>
                                <td>@s.Course</td>
                                <td>@s.CourseLevel</td>
                                <td>
                                    <span class="@(s.RemainingSession > 5 ? "text-success" : "text-danger") fw-semibold">@s.RemainingSession</span>
                                </td>
                                <td><span class="points-badge">@s.Points</span></td>
                                <td>
                                    <a asp-controller="Admin" asp-action="StudentInfo" asp-route-id="@s.Id" class="btn btn-sm btn-ccs">
                                        <i class="fas fa-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

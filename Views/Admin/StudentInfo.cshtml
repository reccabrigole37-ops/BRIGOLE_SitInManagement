@model BRIGOLE_SitInManagement.Models.Student
@{
    ViewData["Title"] = "Student Info";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var history = ViewBag.History as List<BRIGOLE_SitInManagement.Models.SitInRecord> ?? new();
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar" style="background:var(--ccs-gold)"><i class="fas fa-user-shield"></i></div>
            <div class="user-name">@User.Identity?.Name</div>
            <div class="user-id" style="color:rgba(255,255,255,0.5)">Administrator</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="StudentList"><i class="fas fa-users"></i>Student List</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Leaderboard"><i class="fas fa-trophy"></i>Leaderboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Announcements"><i class="fas fa-bullhorn"></i>Announcements</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Reservations"><i class="fas fa-calendar-check"></i>Reservations</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-controller="Admin" asp-action="StudentList" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back
            </a>
            <div>
                <h4 class="fw-bold mb-0" style="color:var(--ccs-purple)">Student Profile</h4>
                <small class="text-muted">@Model.IdNumber</small>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="ccs-card h-100">
                    <div class="ccs-card-header"><i class="fas fa-user me-2"></i>Student Info</div>
                    <div class="p-3">
                        <div class="text-center mb-3">
                            <div class="user-avatar mx-auto mb-2" style="width:70px;height:70px;font-size:2rem">
                                @Model.FirstName.Substring(0,1).ToUpper()
                            </div>
                            <div class="fw-bold">@Model.FullName</div>
                            <div class="text-muted small">@Model.Course — Year @Model.CourseLevel</div>
                        </div>
                        <table class="table table-sm">
                            <tr><td class="text-muted small">ID Number</td><td><code>@Model.IdNumber</code></td></tr>
                            <tr><td class="text-muted small">Email</td><td class="small">@Model.Email</td></tr>
                            <tr><td class="text-muted small">Address</td><td class="small">@Model.Address</td></tr>
                            <tr><td class="text-muted small">Sessions Left</td><td class="fw-bold @(Model.RemainingSession > 5 ? "text-success" : "text-danger")">@Model.RemainingSession</td></tr>
                            <tr><td class="text-muted small">Total Sessions</td><td>@history.Count</td></tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="ccs-card mb-3">
                    <div class="ccs-card-header d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-star me-2" style="color:var(--ccs-gold)"></i>Reward Points</span>
                        <span class="points-badge">⭐ @Model.Points pts</span>
                    </div>
                    <div class="p-3">
                        <form asp-controller="Admin" asp-action="AddPoints" method="post" class="d-flex gap-2 align-items-end">
                            <input type="hidden" name="studentId" value="@Model.Id" />
                            <div>
                                <label class="form-label small fw-semibold">Add Points</label>
                                <input type="number" name="points" class="form-control" style="width:120px" value="1" min="1" max="100" />
                            </div>
                            <button type="submit" class="btn btn-gold"><i class="fas fa-plus me-1"></i>Add Points</button>
                        </form>
                    </div>
                </div>
                <div class="ccs-card">
                    <div class="ccs-card-header"><i class="fas fa-history me-2"></i>Sit-in History (@history.Count sessions)</div>
                    <div style="max-height:280px; overflow-y:auto;">
                        <table class="table ccs-table mb-0">
                            <thead><tr><th>PC</th><th>Purpose</th><th>Time In</th><th>Time Out</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var r in history)
                                {
                                    <tr>
                                        <td>PC #@r.PcNumber</td>
                                        <td>@r.Purpose</td>
                                        <td>@r.TimeIn.ToString("MMM dd, h:mm tt")</td>
                                        <td>@(r.TimeOut.HasValue ? r.TimeOut.Value.ToString("h:mm tt") : "—")</td>
                                        <td>
                                            @if (r.IsActive)
                                            {
                                                <span class="status-active">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Done</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (!history.Any())
                        {
                            <div class="p-3 text-center text-muted small">No sit-in sessions recorded</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

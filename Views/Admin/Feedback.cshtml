@model List<BRIGOLE_SitInManagement.Models.SitInRecord>
@{
    ViewData["Title"] = "Student Feedback";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar" style="background:var(--ccs-gold)"><i class="fas fa-user-shield"></i></div>
            <div class="user-name">@User.Identity?.Name</div>
            <div class="user-id" style="color:rgba(255,255,255,0.5)">Administrator</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="SitInRecords"><i class="fas fa-list-alt"></i>Sit-in Records</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Analytics"><i class="fas fa-chart-pie"></i>Analytics</a>
            <a class="nav-link" asp-controller="Admin" asp-action="StudentList"><i class="fas fa-users"></i>Student List</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Leaderboard"><i class="fas fa-trophy"></i>Leaderboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Announcements"><i class="fas fa-bullhorn"></i>Announcements</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Reservations"><i class="fas fa-calendar-check"></i>Reservations</a>
            <a class="nav-link active" asp-controller="Admin" asp-action="Feedback"><i class="fas fa-comment-dots"></i>Feedback</a>
            <a class="nav-link" asp-controller="Admin" asp-action="ExportCsv"><i class="fas fa-file-csv"></i>Export CSV</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-comment-dots me-2"></i>Student Feedback</h4>

        <div class="ccs-card">
            <div class="ccs-card-header"><i class="fas fa-comments me-2"></i>All Feedback (@Model.Count)</div>
            @if (Model.Any())
            {
                @foreach (var r in Model)
                {
                    <div class="p-3 border-bottom">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold">@r.StudentName <code class="ms-2" style="font-size:0.78rem">@r.StudentIdNumber</code></div>
                                <div class="text-muted small">PC #@r.PcNumber — @r.Purpose — @r.TimeIn.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                        <div class="mt-2 p-2 rounded" style="background:#f8f9fa; border-left:3px solid var(--ccs-purple);">
                            <i class="fas fa-quote-left me-2 text-muted" style="font-size:0.8rem"></i>
                            <span class="small">@r.Feedback</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="p-4 text-center text-muted"><i class="fas fa-comment-slash fa-2x mb-2 d-block"></i>No feedback submitted yet</div>
            }
        </div>
    </div>
</div>

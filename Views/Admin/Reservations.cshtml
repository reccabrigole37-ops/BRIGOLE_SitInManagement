@model List<BRIGOLE_SitInManagement.Models.Reservation>
@{
    ViewData["Title"] = "Reservations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar" style="background:var(--ccs-gold)"><i class="fas fa-user-shield"></i></div>
            <div class="user-name">@User.Identity?.Name</div>
            <div class="user-id" style="color:rgba(255,255,255,0.5)">Administrator</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="SitInRecords"><i class="fas fa-list-alt"></i>Sit-in Records</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Analytics"><i class="fas fa-chart-pie"></i>Analytics</a>
            <a class="nav-link" asp-controller="Admin" asp-action="StudentList"><i class="fas fa-users"></i>Student List</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Leaderboard"><i class="fas fa-trophy"></i>Leaderboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Announcements"><i class="fas fa-bullhorn"></i>Announcements</a>
            <a class="nav-link active" asp-controller="Admin" asp-action="Reservations"><i class="fas fa-calendar-check"></i>Reservations</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Feedback"><i class="fas fa-comment-dots"></i>Feedback</a>
            <a class="nav-link" asp-controller="Admin" asp-action="ExportCsv"><i class="fas fa-file-csv"></i>Export CSV</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-calendar-check me-2"></i>Lab Reservations</h4>

        <div class="ccs-card">
            <div class="ccs-card-header"><i class="fas fa-list me-2"></i>All Reservations</div>
            <div class="table-responsive">
                <table class="table ccs-table mb-0">
                    <thead>
                        <tr><th>ID</th><th>Student</th><th>PC</th><th>Purpose</th><th>Date</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.Id</td>
                                <td>
                                    <div class="fw-semibold small">@r.StudentName</div>
                                    <code style="font-size:0.75rem">@r.StudentIdNumber</code>
                                </td>
                                <td>PC #@r.PcNumber</td>
                                <td>@r.Purpose</td>
                                <td>@r.ReservationDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="status-@r.Status.ToLower()">@r.Status</span></td>
                                <td>
                                    @if (r.Status == "Pending")
                                    {
                                        <form asp-controller="Admin" asp-action="ApproveReservation" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-sm btn-success me-1"><i class="fas fa-check me-1"></i>Approve</button>
                                        </form>
                                        <form asp-controller="Admin" asp-action="DenyReservation" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-times me-1"></i>Deny</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@(r.AdminNote ?? "—")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.Any())
                {
                    <div class="p-4 text-center text-muted"><i class="fas fa-calendar-times fa-2x mb-2 d-block"></i>No reservations found</div>
                }
            </div>
        </div>
    </div>
</div>

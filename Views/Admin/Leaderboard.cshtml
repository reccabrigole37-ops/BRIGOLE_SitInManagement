@model List<BRIGOLE_SitInManagement.Models.Student>
@{
    ViewData["Title"] = "Leaderboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar" style="background:var(--ccs-gold)"><i class="fas fa-user-shield"></i></div>
            <div class="user-name">@User.Identity?.Name</div>
            <div class="user-id" style="color:rgba(255,255,255,0.5)">Administrator</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="SitInRecords"><i class="fas fa-list-alt"></i>Sit-in Records</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Analytics"><i class="fas fa-chart-pie"></i>Analytics</a>
            <a class="nav-link" asp-controller="Admin" asp-action="StudentList"><i class="fas fa-users"></i>Student List</a>
            <a class="nav-link active" asp-controller="Admin" asp-action="Leaderboard"><i class="fas fa-trophy"></i>Leaderboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Announcements"><i class="fas fa-bullhorn"></i>Announcements</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Reservations"><i class="fas fa-calendar-check"></i>Reservations</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Feedback"><i class="fas fa-comment-dots"></i>Feedback</a>
            <a class="nav-link" asp-controller="Admin" asp-action="ExportCsv"><i class="fas fa-file-csv"></i>Export CSV</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-trophy me-2" style="color:var(--ccs-gold)"></i>Points Leaderboard</h4>

        <div class="ccs-card">
            <div class="ccs-card-header"><i class="fas fa-medal me-2"></i>Top Students by Points</div>
            <div class="table-responsive">
                <table class="table ccs-table mb-0">
                    <thead>
                        <tr><th>Rank</th><th>Student</th><th>ID Number</th><th>Course</th><th>Points</th><th>Sessions Left</th><th>Add Points</th></tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var s = Model[i];
                            int rank = i + 1;
                            string rankIcon = rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : $"#{rank}";
                            <tr class="leaderboard-row rank-@rank">
                                <td style="font-size:1.2rem">@rankIcon</td>
                                <td class="fw-semibold">@s.FullName</td>
                                <td><code>@s.IdNumber</code></td>
                                <td>@s.Course</td>
                                <td><span class="points-badge">⭐ @s.Points</span></td>
                                <td>@s.RemainingSession</td>
                                <td>
                                    <form asp-controller="Admin" asp-action="AddPoints" method="post" class="d-flex gap-1 align-items-center">
                                        <input type="hidden" name="studentId" value="@s.Id" />
                                        <input type="number" name="points" class="form-control form-control-sm" style="width:70px" value="1" min="1" max="100" />
                                        <button type="submit" class="btn btn-sm btn-gold"><i class="fas fa-plus"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.Any())
                {
                    <div class="p-4 text-center text-muted"><i class="fas fa-trophy fa-2x mb-2 d-block"></i>No students yet</div>
                }
            </div>
        </div>
    </div>
</div>

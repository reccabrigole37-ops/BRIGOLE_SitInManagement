@model List<BRIGOLE_SitInManagement.Models.Announcement>
@{
    ViewData["Title"] = "Manage Announcements";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar" style="background:var(--ccs-gold)"><i class="fas fa-user-shield"></i></div>
            <div class="user-name">@User.Identity?.Name</div>
            <div class="user-id" style="color:rgba(255,255,255,0.5)">Administrator</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Admin" asp-action="SitInRecords"><i class="fas fa-list-alt"></i>Sit-in Records</a>
            <a class="nav-link" asp-controller="Admin" asp-action="StudentList"><i class="fas fa-users"></i>Student List</a>
            <a class="nav-link active" asp-controller="Admin" asp-action="Announcements"><i class="fas fa-bullhorn"></i>Announcements</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Reservations"><i class="fas fa-calendar-check"></i>Reservations</a>
            <a class="nav-link" asp-controller="Admin" asp-action="Feedback"><i class="fas fa-comment-dots"></i>Feedback</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-bullhorn me-2"></i>Announcements</h4>

        <div class="ccs-card mb-4">
            <div class="ccs-card-header"><i class="fas fa-plus me-2"></i>Create Announcement</div>
            <div class="p-3">
                <form asp-controller="Admin" asp-action="CreateAnnouncement" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Title</label>
                        <input name="title" class="form-control" placeholder="Announcement title" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Content</label>
                        <textarea name="content" class="form-control" rows="4" placeholder="Write your announcement..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-ccs"><i class="fas fa-paper-plane me-2"></i>Post Announcement</button>
                </form>
            </div>
        </div>

        <div class="ccs-card">
            <div class="ccs-card-header"><i class="fas fa-list me-2"></i>All Announcements (@Model.Count)</div>
            @if (Model.Any())
            {
                @foreach (var a in Model)
                {
                    <div class="p-3 border-bottom d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">@a.Title</div>
                            <div class="text-muted small mt-1">@a.Content</div>
                            <div class="text-muted" style="font-size:0.78rem; margin-top:4px">
                                <i class="far fa-calendar me-1"></i>@a.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
                            </div>
                        </div>
                        <form asp-controller="Admin" asp-action="DeleteAnnouncement" method="post" class="ms-3">
                            <input type="hidden" name="id" value="@a.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this announcement?')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                }
            }
            else
            {
                <div class="p-4 text-center text-muted"><i class="fas fa-inbox fa-2x mb-2 d-block"></i>No announcements yet</div>
            }
        </div>
    </div>
</div>

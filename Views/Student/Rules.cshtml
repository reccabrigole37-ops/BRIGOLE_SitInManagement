@{
    ViewData["Title"] = "Lab Rules & Regulations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper())</div>
            <div class="user-name">@User.Identity?.Name</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Student" asp-action="EditProfile"><i class="fas fa-user-edit"></i>Edit Profile</a>
            <a class="nav-link" asp-controller="Student" asp-action="Notifications"><i class="fas fa-bell"></i>Announcements</a>
            <div class="sidebar-section-title">Lab</div>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link" asp-controller="Student" asp-action="Reservation"><i class="fas fa-calendar-plus"></i>Reserve a PC</a>
            <a class="nav-link" asp-controller="Student" asp-action="MyReservations"><i class="fas fa-calendar-check"></i>My Reservations</a>
            <a class="nav-link active" asp-controller="Student" asp-action="Rules"><i class="fas fa-book"></i>Rules & Regulations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rewards"><i class="fas fa-trophy"></i>Rewards & Points</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-book me-2"></i>Laboratory Rules & Regulations</h4>

        <div class="ccs-card" style="max-width:800px;">
            <div class="ccs-card-header"><i class="fas fa-gavel me-2"></i>CCS Laboratory Policies</div>
            <div class="p-4">
                @{
                    var rules = new[] {
                        ("General Conduct", new[]{
                            "Students must present their ID before entering the laboratory.",
                            "Maintain cleanliness and orderliness at all times.",
                            "No eating, drinking, or smoking inside the laboratory.",
                            "Observe proper decorum and respect fellow users and laboratory staff."
                        }),
                        ("Computer Use Policy", new[]{
                            "Use only the assigned or available computer units.",
                            "Unauthorized installation of software is strictly prohibited.",
                            "Do not access inappropriate or illegal websites.",
                            "Log off after each session and report any hardware/software issues."
                        }),
                        ("Sit-in Sessions", new[]{
                            "Students are entitled to a maximum of 30 sit-in sessions per semester.",
                            "Sessions are deducted upon each approved sit-in.",
                            "Students must state their purpose of use before sitting in.",
                            "Sessions may be extended at the discretion of the laboratory administrator."
                        }),
                        ("Reservations", new[]{
                            "Reservations must be submitted at least one day in advance.",
                            "Reserved slots not used within 15 minutes will be forfeited.",
                            "Approved reservations do not guarantee a deduction of remaining sessions.",
                            "Cancellations should be made at least 30 minutes before the reserved time."
                        }),
                        ("Violations & Consequences", new[]{
                            "First offense: Verbal warning.",
                            "Second offense: Written warning and temporary suspension of lab privileges.",
                            "Third offense: Permanent revocation of sit-in privileges for the semester.",
                            "Serious misconduct may be referred to the Office of Student Affairs."
                        })
                    };

                    int ruleNum = 1;
                    foreach (var ruleSection in rules)
                    {
                        <div class="mb-4">
                            <h6 class="fw-bold d-flex align-items-center gap-2 mb-3" style="color:var(--ccs-purple)">
                                <span class="d-flex align-items-center justify-content-center rounded-circle text-white fw-bold"
                                      style="width:28px;height:28px;background:var(--ccs-purple);font-size:0.8rem;">@(ruleNum++)</span>
                                @ruleSection.Item1
                            </h6>
                            <ul class="list-unstyled ms-3">
                                @foreach (var rule in ruleSection.Item2)
                                {
                                    <li class="mb-2 d-flex align-items-start gap-2">
                                        <i class="fas fa-chevron-right mt-1" style="color:var(--ccs-gold); font-size:0.7rem;"></i>
                                        <span>@rule</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                }
                <div class="alert alert-warning mt-3 mb-0" style="border-radius:10px;">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Reminder:</strong> By using the CCS laboratory, you agree to abide by these rules and regulations.
                    Non-compliance may result in the suspension of laboratory privileges.
                </div>
            </div>
        </div>
    </div>
</div>

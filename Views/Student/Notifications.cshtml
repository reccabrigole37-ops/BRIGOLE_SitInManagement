@model List<BRIGOLE_SitInManagement.Models.Announcement>
@{
    ViewData["Title"] = "Announcements";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper())</div>
            <div class="user-name">@User.Identity?.Name</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Student" asp-action="EditProfile"><i class="fas fa-user-edit"></i>Edit Profile</a>
            <a class="nav-link active" asp-controller="Student" asp-action="Notifications"><i class="fas fa-bell"></i>Announcements</a>
            <div class="sidebar-section-title">Lab</div>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link" asp-controller="Student" asp-action="Reservation"><i class="fas fa-calendar-plus"></i>Reserve a PC</a>
            <a class="nav-link" asp-controller="Student" asp-action="MyReservations"><i class="fas fa-calendar-check"></i>My Reservations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rules"><i class="fas fa-book"></i>Rules & Regulations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rewards"><i class="fas fa-trophy"></i>Rewards & Points</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-bullhorn me-2"></i>Announcements</h4>

        @if (Model.Any())
        {
            @foreach (var a in Model)
            {
                <div class="ccs-card mb-3">
                    <div class="p-4">
                        <div class="d-flex align-items-start gap-3">
                            <div class="d-flex align-items-center justify-content-center rounded-circle"
                                 style="width:44px;height:44px;background:var(--ccs-purple);flex-shrink:0;">
                                <i class="fas fa-bullhorn text-white"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1" style="color:var(--ccs-purple)">@a.Title</h6>
                                <p class="mb-2">@a.Content</p>
                                <div class="text-muted small">
                                    <i class="far fa-calendar me-1"></i>@a.CreatedAt.ToString("MMMM dd, yyyy h:mm tt")
                                    &mdash; <i class="fas fa-user me-1"></i>@a.CreatedBy
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="ccs-card p-5 text-center text-muted">
                <i class="fas fa-inbox fa-3x mb-3 d-block" style="color:var(--ccs-border)"></i>
                <p class="mb-0">No announcements at this time.</p>
            </div>
        }
    </div>
</div>

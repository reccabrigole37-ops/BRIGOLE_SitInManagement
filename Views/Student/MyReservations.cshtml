@model List<BRIGOLE_SitInManagement.Models.Reservation>
@{
    ViewData["Title"] = "My Reservations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper())</div>
            <div class="user-name">@User.Identity?.Name</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Student" asp-action="EditProfile"><i class="fas fa-user-edit"></i>Edit Profile</a>
            <a class="nav-link" asp-controller="Student" asp-action="Notifications"><i class="fas fa-bell"></i>Announcements</a>
            <div class="sidebar-section-title">Lab</div>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link" asp-controller="Student" asp-action="Reservation"><i class="fas fa-calendar-plus"></i>Reserve a PC</a>
            <a class="nav-link active" asp-controller="Student" asp-action="MyReservations"><i class="fas fa-calendar-check"></i>My Reservations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rules"><i class="fas fa-book"></i>Rules & Regulations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rewards"><i class="fas fa-trophy"></i>Rewards & Points</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold mb-0" style="color:var(--ccs-purple)"><i class="fas fa-calendar-check me-2"></i>My Reservations</h4>
            <a asp-controller="Student" asp-action="Reservation" class="btn btn-ccs"><i class="fas fa-plus me-1"></i>New Reservation</a>
        </div>

        <div class="ccs-card">
            <div class="ccs-card-header"><i class="fas fa-list me-2"></i>Reservation History</div>
            @if (Model.Any())
            {
                <table class="table ccs-table mb-0">
                    <thead><tr><th>PC</th><th>Purpose</th><th>Date</th><th>Status</th><th>Note</th></tr></thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td><strong>PC #@r.PcNumber</strong></td>
                                <td>@r.Purpose</td>
                                <td>@r.ReservationDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="status-@r.Status.ToLower()">@r.Status</span></td>
                                <td class="text-muted small">@(r.AdminNote ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="p-4 text-center text-muted">
                    <i class="fas fa-calendar-times fa-2x mb-2 d-block"></i>
                    No reservations yet.
                    <a asp-controller="Student" asp-action="Reservation" class="d-block mt-2" style="color:var(--ccs-purple)">Make a reservation →</a>
                </div>
            }
        </div>
    </div>
</div>

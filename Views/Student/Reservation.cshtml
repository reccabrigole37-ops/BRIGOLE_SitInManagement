@model BRIGOLE_SitInManagement.Models.Reservation
@{
    ViewData["Title"] = "Reserve a PC";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper())</div>
            <div class="user-name">@User.Identity?.Name</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Student" asp-action="EditProfile"><i class="fas fa-user-edit"></i>Edit Profile</a>
            <a class="nav-link" asp-controller="Student" asp-action="Notifications"><i class="fas fa-bell"></i>Announcements</a>
            <div class="sidebar-section-title">Lab</div>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link active" asp-controller="Student" asp-action="Reservation"><i class="fas fa-calendar-plus"></i>Reserve a PC</a>
            <a class="nav-link" asp-controller="Student" asp-action="MyReservations"><i class="fas fa-calendar-check"></i>My Reservations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rules"><i class="fas fa-book"></i>Rules & Regulations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rewards"><i class="fas fa-trophy"></i>Rewards & Points</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-calendar-plus me-2"></i>Reserve a PC</h4>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="ccs-card">
                    <div class="ccs-card-header"><i class="fas fa-clipboard-list me-2"></i>Reservation Form</div>
                    <div class="p-4">
                        <form asp-controller="Student" asp-action="Reservation" method="post">
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">PC Number <span class="text-danger">*</span></label>
                                <input asp-for="PcNumber" type="number" min="1" max="50" class="form-control" placeholder="Enter PC number (1-50)" required />
                                <div class="form-text">Choose an available PC from the grid →</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Purpose <span class="text-danger">*</span></label>
                                <select asp-for="Purpose" class="form-select" required>
                                    <option value="">-- Select Purpose --</option>
                                    <option>C Programming</option>
                                    <option>Java Programming</option>
                                    <option>Web Development</option>
                                    <option>Database</option>
                                    <option>Research / Thesis</option>
                                    <option>Online Class</option>
                                    <option>Other</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Preferred Date <span class="text-danger">*</span></label>
                                <input asp-for="ReservationDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                            <button type="submit" class="btn btn-ccs w-100">
                                <i class="fas fa-calendar-check me-2"></i>Submit Reservation
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="ccs-card">
                    <div class="ccs-card-header"><i class="fas fa-desktop me-2"></i>PC Availability (1–50)</div>
                    <div class="p-3">
                        <div class="d-flex gap-3 mb-3 small">
                            <span><span class="pc-slot available" style="display:inline-flex;width:24px;height:24px;font-size:0.6rem;">✓</span> Available</span>
                        </div>
                        <div class="pc-grid">
                            @for (int i = 1; i <= 50; i++)
                            {
                                <div class="pc-slot available" onclick="selectPc(@i)" id="pc-@i">
                                    <i class="fas fa-desktop" style="font-size:1rem"></i>
                                    <span style="font-size:0.7rem">@i</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function selectPc(num) {
    document.getElementById('PcNumber').value = num;
    document.querySelectorAll('.pc-slot').forEach(el => el.style.outline = 'none');
    document.getElementById('pc-' + num).style.outline = '3px solid var(--ccs-purple)';
}
</script>
}

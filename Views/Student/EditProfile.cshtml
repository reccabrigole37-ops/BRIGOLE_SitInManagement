@model BRIGOLE_SitInManagement.Models.Student
@{
    ViewData["Title"] = "Edit Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(Model.FirstName.Substring(0,1).ToUpper())</div>
            <div class="user-name">@Model.FullName</div>
            <div class="user-id">@Model.IdNumber</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link active" asp-controller="Student" asp-action="EditProfile"><i class="fas fa-user-edit"></i>Edit Profile</a>
            <a class="nav-link" asp-controller="Student" asp-action="Notifications"><i class="fas fa-bell"></i>Announcements</a>
            <div class="sidebar-section-title">Lab</div>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link" asp-controller="Student" asp-action="Reservation"><i class="fas fa-calendar-plus"></i>Reserve a PC</a>
            <a class="nav-link" asp-controller="Student" asp-action="MyReservations"><i class="fas fa-calendar-check"></i>My Reservations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rules"><i class="fas fa-book"></i>Rules & Regulations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rewards"><i class="fas fa-trophy"></i>Rewards & Points</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-user-edit me-2"></i>Edit Profile</h4>

        <div class="ccs-card" style="max-width:700px;">
            <div class="ccs-card-header"><i class="fas fa-id-card me-2"></i>Personal Information</div>
            <div class="p-4">
                <form asp-controller="Student" asp-action="EditProfile" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-semibold text-muted">ID Number (cannot be changed)</label>
                            <input class="form-control bg-light" value="@Model.IdNumber" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Last Name</label>
                            <input asp-for="LastName" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">First Name</label>
                            <input asp-for="FirstName" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Middle Name</label>
                            <input asp-for="MiddleName" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Course Level</label>
                            <input asp-for="CourseLevel" type="number" min="1" max="5" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label small fw-semibold">Course</label>
                            <select asp-for="Course" class="form-select">
                                <option value="BSIT">BSIT</option>
                                <option value="BSCS">BSCS</option>
                                <option value="BSIS">BSIS</option>
                                <option value="BSEMC">BSEMC</option>
                                <option value="ACT">ACT</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Email</label>
                            <input asp-for="Email" type="email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold">Address</label>
                            <input asp-for="Address" class="form-control" />
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-ccs"><i class="fas fa-save me-2"></i>Save Changes</button>
                        <a asp-controller="Student" asp-action="Dashboard" class="btn btn-outline-secondary ms-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@model BRIGOLE_SitInManagement.Models.DashboardViewModel
@{
    ViewData["Title"] = "Student Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(Model.Student?.FirstName?.Substring(0,1).ToUpper())</div>
            <div class="user-name">@Model.Student?.FullName</div>
            <div class="user-id">@Model.Student?.IdNumber</div>
            <div class="mt-1"><span class="points-badge"><i class="fas fa-star me-1"></i>@Model.Student?.Points pts</span></div>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-section-title">Main</div>
            <a class="nav-link active" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Student" asp-action="EditProfile"><i class="fas fa-user-edit"></i>Edit Profile</a>
            <a class="nav-link" asp-controller="Student" asp-action="Notifications"><i class="fas fa-bell"></i>Announcements</a>
            <div class="sidebar-section-title">Lab</div>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link" asp-controller="Student" asp-action="Reservation"><i class="fas fa-calendar-plus"></i>Reserve a PC</a>
            <a class="nav-link" asp-controller="Student" asp-action="MyReservations"><i class="fas fa-calendar-check"></i>My Reservations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rules"><i class="fas fa-book"></i>Rules & Regulations</a>
            <div class="sidebar-section-title">Rewards</div>
            <a class="nav-link" asp-controller="Student" asp-action="Rewards"><i class="fas fa-trophy"></i>Rewards & Points</a>
            <div class="sidebar-section-title">Account</div>
            <a class="nav-link text-danger-hover" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>

    <!-- Content -->
    <div class="dashboard-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-0" style="color:var(--ccs-purple)">Student Dashboard</h4>
                <small class="text-muted">Welcome back, @Model.Student?.FirstName!</small>
            </div>
            <span class="text-muted small"><i class="far fa-clock me-1"></i>@DateTime.Now.ToString("MMMM dd, yyyy")</span>
        </div>

        <!-- Stats Row -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-number">@Model.Student?.RemainingSession</div>
                    <div class="stat-label"><i class="fas fa-desktop me-1"></i>Remaining Sessions</div>
                    <i class="fas fa-laptop-code stat-icon"></i>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-number">@Model.TotalSessions</div>
                    <div class="stat-label"><i class="fas fa-history me-1"></i>Total Sit-ins</div>
                    <i class="fas fa-chart-bar stat-icon"></i>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-number" style="color:var(--ccs-gold)">@Model.Student?.Points</div>
                    <div class="stat-label"><i class="fas fa-star me-1"></i>Reward Points</div>
                    <i class="fas fa-trophy stat-icon"></i>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <!-- Announcements -->
            <div class="col-lg-6">
                <div class="ccs-card">
                    <div class="ccs-card-header d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-bullhorn me-2"></i>Latest Announcements</span>
                    </div>
                    <div class="p-0">
                        @if (Model.Announcements.Any())
                        {
                            @foreach (var a in Model.Announcements)
                            {
                                <div class="p-3 border-bottom">
                                    <div class="fw-semibold" style="font-size:0.9rem">@a.Title</div>
                                    <div class="text-muted small mt-1">@a.Content</div>
                                    <div class="text-muted" style="font-size:0.75rem; margin-top:4px"><i class="far fa-clock me-1"></i>@a.CreatedAt.ToString("MMM dd, yyyy")</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted"><i class="fas fa-inbox fa-2x mb-2 d-block"></i>No announcements</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Recent Sessions -->
            <div class="col-lg-6">
                <div class="ccs-card">
                    <div class="ccs-card-header d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-history me-2"></i>Recent Sessions</span>
                        <a asp-controller="Student" asp-action="SitInHistory" class="btn btn-sm btn-gold">View All</a>
                    </div>
                    <div class="p-0">
                        @if (Model.RecentSessions.Any())
                        {
                            @foreach (var r in Model.RecentSessions)
                            {
                                <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small fw-semibold">PC #@r.PcNumber — @r.Purpose</div>
                                        <div class="text-muted" style="font-size:0.77rem">@r.TimeIn.ToString("MMM dd, yyyy h:mm tt")</div>
                                    </div>
                                    @if (r.IsActive)
                                    {
                                        <span class="status-active"><i class="fas fa-circle me-1" style="font-size:0.6rem"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@(r.TimeOut.HasValue ? r.TimeOut.Value.ToString("h:mm tt") : "-")</span>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted"><i class="fas fa-desktop fa-2x mb-2 d-block"></i>No sessions yet</div>
                        }
                    </div>
                </div>
            </div>

            <!-- Reservations -->
            <div class="col-12">
                <div class="ccs-card">
                    <div class="ccs-card-header d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-calendar-alt me-2"></i>My Reservations</span>
                        <a asp-controller="Student" asp-action="Reservation" class="btn btn-sm btn-gold"><i class="fas fa-plus me-1"></i>New Reservation</a>
                    </div>
                    <div class="p-0">
                        @if (Model.Reservations.Any())
                        {
                            <table class="table mb-0">
                                <thead><tr><th>PC</th><th>Purpose</th><th>Date</th><th>Status</th></tr></thead>
                                <tbody>
                                    @foreach (var r in Model.Reservations)
                                    {
                                        <tr>
                                            <td>PC #@r.PcNumber</td>
                                            <td>@r.Purpose</td>
                                            <td>@r.ReservationDate.ToString("MMM dd, yyyy")</td>
                                            <td><span class="status-@r.Status.ToLower()">@r.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted"><i class="fas fa-calendar-times fa-2x mb-2 d-block"></i>No reservations yet</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

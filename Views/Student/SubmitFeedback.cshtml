@model BRIGOLE_SitInManagement.Models.SitInRecord
@{
    ViewData["Title"] = "Submit Feedback";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper())</div>
            <div class="user-name">@User.Identity?.Name</div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-comment-dots me-2"></i>Submit Feedback</h4>

        <div class="ccs-card" style="max-width:600px;">
            <div class="ccs-card-header"><i class="fas fa-star me-2"></i>Rate Your Session</div>
            <div class="p-4">
                <div class="mb-4 p-3 rounded" style="background:#f8f9fa;">
                    <div class="small text-muted fw-semibold mb-1">Session Details</div>
                    <div><strong>PC #@Model.PcNumber</strong> — @Model.Purpose</div>
                    <div class="text-muted small">@Model.TimeIn.ToString("MMMM dd, yyyy h:mm tt")</div>
                </div>

                <form asp-controller="Student" asp-action="SubmitFeedback" asp-route-id="@Model.Id" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Your Feedback <span class="text-danger">*</span></label>
                        <textarea name="feedback" class="form-control" rows="5" required
                                  placeholder="Share your experience... Was the lab helpful? Any issues with equipment? Suggestions for improvement?"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-ccs"><i class="fas fa-paper-plane me-2"></i>Submit Feedback</button>
                        <a asp-controller="Student" asp-action="SitInHistory" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

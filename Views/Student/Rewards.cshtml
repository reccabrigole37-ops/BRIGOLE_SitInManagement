@model BRIGOLE_SitInManagement.Models.Student
@{
    ViewData["Title"] = "Rewards & Points";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var leaderboard = ViewBag.Leaderboard as List<BRIGOLE_SitInManagement.Models.Student> ?? new();
}

<div class="dashboard-layout">
    <div class="sidebar">
        <div class="sidebar-user">
            <div class="user-avatar">@(Model.FirstName.Substring(0,1).ToUpper())</div>
            <div class="user-name">@Model.FullName</div>
            <div class="user-id">@Model.IdNumber</div>
            <div class="mt-1"><span class="points-badge">⭐ @Model.Points pts</span></div>
        </div>
        <nav class="sidebar-nav">
            <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="fas fa-home"></i>Dashboard</a>
            <a class="nav-link" asp-controller="Student" asp-action="EditProfile"><i class="fas fa-user-edit"></i>Edit Profile</a>
            <a class="nav-link" asp-controller="Student" asp-action="Notifications"><i class="fas fa-bell"></i>Announcements</a>
            <div class="sidebar-section-title">Lab</div>
            <a class="nav-link" asp-controller="Student" asp-action="SitInHistory"><i class="fas fa-history"></i>Sit-in History</a>
            <a class="nav-link" asp-controller="Student" asp-action="Reservation"><i class="fas fa-calendar-plus"></i>Reserve a PC</a>
            <a class="nav-link" asp-controller="Student" asp-action="MyReservations"><i class="fas fa-calendar-check"></i>My Reservations</a>
            <a class="nav-link" asp-controller="Student" asp-action="Rules"><i class="fas fa-book"></i>Rules & Regulations</a>
            <a class="nav-link active" asp-controller="Student" asp-action="Rewards"><i class="fas fa-trophy"></i>Rewards & Points</a>
            <a class="nav-link" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
        </nav>
    </div>
    <div class="dashboard-content">
        <h4 class="fw-bold mb-4" style="color:var(--ccs-purple)"><i class="fas fa-trophy me-2" style="color:var(--ccs-gold)"></i>Rewards & Points</h4>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card text-center">
                    <div class="stat-number" style="color:var(--ccs-gold); font-size:3rem">@Model.Points</div>
                    <div class="stat-label">Your Points</div>
                    <i class="fas fa-star stat-icon" style="color:var(--ccs-gold); opacity:0.2;"></i>
                </div>
            </div>
            <div class="col-md-8">
                <div class="ccs-card h-100">
                    <div class="ccs-card-header"><i class="fas fa-info-circle me-2"></i>How to Earn Points</div>
                    <div class="p-3">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Complete a sit-in session</li>
                            <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Submit session feedback</li>
                            <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Admin grants bonus points</li>
                            <li class="mb-0 text-muted small mt-2">Points are awarded at admin's discretion based on lab participation.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="ccs-card">
            <div class="ccs-card-header"><i class="fas fa-medal me-2"></i>Top 10 Leaderboard</div>
            <table class="table ccs-table mb-0">
                <thead><tr><th>Rank</th><th>Student</th><th>Course</th><th>Points</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < leaderboard.Count; i++)
                    {
                        var s = leaderboard[i];
                        int rank = i + 1;
                        bool isMe = s.Id == Model.Id;
                        string rankIcon = rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : $"#{rank}";
                        <tr class="leaderboard-row rank-@rank @(isMe ? "table-warning" : "")">
                            <td style="font-size:1.1rem">@rankIcon @(isMe ? "← You" : "")</td>
                            <td class="fw-semibold">@s.FullName</td>
                            <td>@s.Course</td>
                            <td><span class="points-badge">⭐ @s.Points</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

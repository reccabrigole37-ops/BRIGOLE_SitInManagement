@model BRIGOLE_SitInManagement.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Model == null)
{
    return; // safety check
}
<div class="login-page">
    <div class="login-card">
        <div class="login-left">
            <img src="~/images/ccs-logo.png" alt="CCS Logo" onerror="this.outerHTML='<div style=\'font-size:5rem\'>🎓</div>'" />
            <h3>CCS</h3>
            <p>College of Computer Studies<br/><em>Sit-In Monitoring System</em></p>
            <div class="mt-3 text-center">
                <small style="color:rgba(255,255,255,0.5)">© 2024 CCS - UC</small>
            </div>
        </div>
        <div class="login-right">
            <h4>Welcome Back!</h4>
            <p class="text-muted mb-4" style="font-size:0.9rem">Sign in to access your dashboard</p>

            <div class="form-check form-switch mb-4">
                <input class="form-check-input"
                       type="checkbox"
                       id="adminToggle"
                       onchange="
               document.getElementById('isAdminField').value = this.checked;
               document.getElementById('idLabel').textContent =
                   this.checked ? 'Username' : 'ID Number';
           " />
                <label class="form-check-label fw-semibold" for="adminToggle">
                    <i class="fas fa-user-shield me-1"></i>Login as Admin
                </label>
            </div>

            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="IsAdmin" id="isAdminField" />
                @if (!ViewData.ModelState.IsValid &&
                                ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger py-2 small">
                        @foreach (var error in ViewData.ModelState.Values
                                            .SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold small" id="idLabel">ID Number</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                        <input asp-for="IdNumber" class="form-control" placeholder="Enter your ID number" autocomplete="username" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" autocomplete="current-password" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePass()"><i class="fas fa-eye" id="eyeIcon"></i></button>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                        <label class="form-check-label small">Remember me</label>
                    </div>
                    <a href="#" class="text-decoration-none small" style="color:var(--ccs-purple)">Forgot password?</a>
                </div>
                <button type="submit" class="btn btn-login">
                    <i class="fas fa-sign-in-alt me-2"></i>Login
                </button>
                <p class="text-center mt-3 mb-0 small">Don't have an account?
                    <a asp-controller="Account" asp-action="Register" class="fw-bold" style="color:var(--ccs-purple)">Register</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function toggleRole(isAdmin) {
    document.getElementById('isAdminField').value = isAdmin;
    document.getElementById('idLabel').textContent = isAdmin ? 'Username' : 'ID Number';
    document.querySelectorAll('.login-right .btn').forEach((b, i) => {
        if (i === 0) { b.className = b.className.replace(isAdmin ? 'btn-ccs' : 'btn-outline-secondary', isAdmin ? 'btn-outline-secondary' : 'btn-ccs'); }
        if (i === 1) { b.className = b.className.replace(!isAdmin ? 'btn-ccs' : 'btn-outline-secondary', !isAdmin ? 'btn-outline-secondary' : 'btn-ccs'); }
    });
    location.reload(); // simple reload; in real app keep state
}
function togglePass() {
    const p = document.getElementById('Password');
    const icon = document.getElementById('eyeIcon');
    if (p.type === 'password') { p.type = 'text'; icon.className = 'fas fa-eye-slash'; }
    else { p.type = 'password'; icon.className = 'fas fa-eye'; }
}
</script>
}
